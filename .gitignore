# Dependencies
node_modules/
.npm

# Environment
.env
.env.local
.env.production
backend/.env

# Logs
logs/
*.log
npm-debug.log*

# Build / runtime
dist/
build/
.cache/

# OS
.DS_Store
Thumbs.db

